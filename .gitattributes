# Normalize line endings to LF for all text files on every platform.
# This overrides core.autocrlf so Windows checkouts don't reintroduce CRLF,
# which otherwise trips the prettier/prettier ESLint rule on every line.
* text=auto eol=lf

# Binary assets — never convert.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.node binary
